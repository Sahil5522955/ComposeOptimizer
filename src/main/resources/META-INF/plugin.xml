<idea-plugin>
    <id>com.sahiljaroli.composeoptimizer</id>
    <name>Compose Optimizer</name>
    <vendor email="sahiljaroli159@gmail.com">SahilJaroli</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                language="kotlin"
                displayName="Compose Optimizer Check"
                groupPath="Kotlin"
                groupName="Jetpack Compose"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.sahiljaroli.composeoptimizer.ComposeOptimizerInspection"/>
    </extensions>
</idea-plugin>